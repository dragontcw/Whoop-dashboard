# Whoop Developer Dashboard (developer-dashboard.whoop.com) -> your app's API keys
WHOOP_CLIENT_ID=your_client_id_here
WHOOP_CLIENT_SECRET=your_client_secret_here

# Must exactly match the redirect URI you register in the Whoop developer dashboard.
# Local dev example: http://localhost:3000/api/auth/callback
# Production example: https://your-app-name.vercel.app/api/auth/callback
WHOOP_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Any long random string — used to encrypt the Whoop tokens stored in your browser cookie.
# Generate one with: openssl rand -hex 32
COOKIE_SECRET=replace_with_a_long_random_string
